<?xml version="1.0" encoding="UTF-8"?>
{% import "macros/cda.xml.j2" as cda %}
<ClinicalDocument xmlns="urn:hl7-org:v3" xmlns:fias="urn:hl7-ru:fias" xmlns:address="urn:hl7-ru:address">
    <!-- CDA Header -->
    <realmCode code="RU"/>
    <typeId root="2.16.840.1.113883.1.3" extension="POCD_MT000040"/>
    {{ cda.id(header.id) }}
    {{ cda.code(header.type_code) }}
    <title>{{ header.title }}</title>
    <effectiveTime value="{{ event_date | hl7date }}"/>
    <confidentialityCode code="N" codeSystem="2.16.840.1.113883.5.25"/>
    <languageCode code="ru-RU"/>

    <!-- Данные пациента, врача и организации (упрощено) -->
    <recordTarget>
        <patientRole>
            {{ cda.id(patient.id) }}
            {{ cda.addr(patient.address) }}
            <patient>
                {{ cda.person(patient.name) }}
                <administrativeGenderCode code="{{ patient.gender.code }}" codeSystem="1.2.643.5.1.13.13.11.1040"/>
                <birthTime value="{{ patient.birth_date | hl7date }}"/>
            </patient>
        </patientRole>
    </recordTarget>

    <!-- Тело документа -->
    <component>
        <structuredBody>
            <!-- Секция ЖАЛОБЫ -->
            <component>
                <section>
                    <code code="S_COMPL" codeSystem="1.2.643.5.1.13.13.99.2.197" displayName="Жалобы"/>
                    <title>Жалобы</title>
                    <text>{{ complaints }}</text>
                </section>
            </component>

            <!-- Секция ДИАГНОЗЫ -->
            <component>
                <section>
                    <code code="DX" codeSystem="1.2.643.5.1.13.13.99.2.197" displayName="Диагноз"/>
                    <title>Диагноз</title>
                    <text>
                        <list>
                        {% for dx in diagnoses %}
                            <item>{{ dx.code.displayName }}: {{ dx.text }}</item>
                        {% endfor %}
                        </list>
                    </text>
                    {% for dx in diagnoses %}
                    <entry>
                        <observation classCode="OBS" moodCode="EVN">
                            {{ cda.code(dx.code) }}
                            <value xsi:type="CD" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
                                   code="{{ dx.code.code }}" codeSystem="1.2.643.5.1.13.13.11.1005"/>
                        </observation>
                    </entry>
                    {% endfor %}
                </section>
            </component>
        </structuredBody>
    </component>
</ClinicalDocument>
